# LiteLLM Gateway — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# -------------------------------------------------------
# Server Configuration
# -------------------------------------------------------
PORT=8000
HOST=0.0.0.0
STREAMLIT_PORT=8501

# -------------------------------------------------------
# LLM API Keys
# -------------------------------------------------------

# Groq (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Cerebras (https://cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Together AI (https://api.together.ai)
TOGETHERAI_API_KEY=your_togetherai_api_key_here

# Mistral (https://console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here

# -------------------------------------------------------
# Local Ollama (optional — for offline/local fallback)
# -------------------------------------------------------
OLLAMA_API_BASE=http://localhost:11434

# -------------------------------------------------------
# Cloud Deployment Overrides (set these in cloud platform secrets)
# -------------------------------------------------------
# PROXY_URL=http://127.0.0.1:8000          # Streamlit → FastAPI internal URL
# STREAMLIT_INTERNAL_URL=http://127.0.0.1:8501  # FastAPI → Streamlit proxy URL
# TRANSFORMERS_OFFLINE=1                   # Use pre-cached model (set in Dockerfile)
