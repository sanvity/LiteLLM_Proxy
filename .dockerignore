# Docker build context exclusions
# Keeps the image lean and prevents secrets from leaking into the image layer

# Secrets — NEVER in the image
.env

# Git metadata
.git
.gitignore
.gitattributes

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.Python

# Development / IDE files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Temporary / backup files
_temp_backup/
*.bak
*.tmp

# Documentation / planning (not needed at runtime)
implementation_plan.md
README.md
*.md

# Test files
test_proxy.py

# Local virtual environments
venv/
.venv/
env/

# Node (if any frontend tooling)
node_modules/
