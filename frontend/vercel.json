{
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://litellm-proxy-backend.onrender.com/health"
    },
    {
      "source": "/metrics",
      "destination": "https://litellm-proxy-backend.onrender.com/metrics"
    },
    {
      "source": "/v1/:path*",
      "destination": "https://litellm-proxy-backend.onrender.com/v1/:path*"
    }
  ]
}
